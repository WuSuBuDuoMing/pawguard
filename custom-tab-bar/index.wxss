.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 998;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.tab-bar.dark { background: #16213E; border-top-color: #2A2A4A; }

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 6rpx;
  transition: all 0.2s ease;
}

.tab-bar__icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-bar__icon {
  font-size: 44rpx;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: grayscale(100%);
  opacity: 0.6;
}

.tab-bar__item.active .tab-bar__icon {
  filter: none;
  opacity: 1;
  transform: scale(1.15);
}

.tab-bar__label {
  font-size: 20rpx;
  margin-top: 4rpx;
  color: #888888;
  transition: color 0.2s ease;
}

.tab-bar__item.active .tab-bar__label {
  color: #FF9F5A;
  font-weight: 600;
}

.tab-bar__badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  padding: 0 8rpx;
  font-size: 18rpx;
  color: #FFFFFF;
  background: #FF4D4F;
  border-radius: 28rpx;
  font-weight: 500;
}
