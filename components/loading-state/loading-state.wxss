.loading {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 120rpx;
}
.loading__dots { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.loading__dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--warm-orange, #FF9F5A);
  animation: bounce 1.4s ease-in-out infinite;
}
.loading__dot:nth-child(2) { animation-delay: 0.16s; }
.loading__dot:nth-child(3) { animation-delay: 0.32s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
.loading__text { font-size: 26rpx; color: var(--text-secondary, #888); }
