.empty {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 120rpx 60rpx;
}
.empty__icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty__title { font-size: 32rpx; font-weight: 500; color: var(--text-primary, #333); margin-bottom: 12rpx; }
.empty__desc { font-size: 26rpx; color: var(--text-secondary, #888); text-align: center; margin-bottom: 32rpx; }
.empty__btn { margin-top: 20rpx; }
