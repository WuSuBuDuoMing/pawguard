<view class="diary-card {{isDarkMode ? 'dark' : ''}}" bindtap="onTap">
  <view class="diary-card__header">
    <text class="diary-card__date">{{diary.date}}</text>
    <text class="diary-card__mood">{{moodIcon}}</text>
  </view>
  <text class="diary-card__title">{{diary.title}}</text>
  <text class="diary-card__content">{{diary.content}}</text>
  <view class="diary-card__images" wx:if="{{diary.images && diary.images.length}}">
    <image wx:for="{{diary.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" class="diary-card__img" wx:if="{{index < 3}}" />
    <view wx:if="{{diary.images.length > 3}}" class="diary-card__more-img">
      <text>+{{diary.images.length - 3}}</text>
    </view>
  </view>
  <view class="diary-card__tags" wx:if="{{diary.tags && diary.tags.length}}">
    <text class="tag tag-orange" wx:for="{{diary.tags}}" wx:key="*this">{{item}}</text>
  </view>
</view>
