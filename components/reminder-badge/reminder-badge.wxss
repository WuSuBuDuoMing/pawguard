.reminder {
  display: inline-flex; align-items: center; padding: 8rpx 20rpx;
  border-radius: 24rpx; font-size: 22rpx;
  background: rgba(255,159,90,0.12); color: #FF9F5A;
}
.reminder.urgent { background: rgba(255,77,79,0.12); color: #FF4D4F; }
.reminder.warning { background: rgba(250,173,20,0.12); color: #FAAD14; }
.reminder__icon { margin-right: 8rpx; }
.reminder__text { margin-right: 12rpx; }
.reminder__badge {
  min-width: 32rpx; height: 32rpx; border-radius: 16rpx;
  background: currentColor; color: #FFF;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; padding: 0 8rpx;
}
