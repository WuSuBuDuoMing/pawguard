.album-grid { display: flex; flex-wrap: wrap; gap: 8rpx; }
.album-grid__item {
  width: calc(33.333% - 6rpx); position: relative;
  border-radius: 16rpx; overflow: hidden;
  aspect-ratio: 1;
}
.album-grid__img { width: 100%; height: 100%; }
.album-grid__overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  padding: 16rpx 12rpx 10rpx;
}
.album-grid__title { font-size: 20rpx; color: #FFF; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.album-grid__empty {
  width: 100%; padding: 120rpx 0;
  display: flex; flex-direction: column; align-items: center;
}
.album-grid__empty .empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.album-grid__empty .empty-desc { font-size: 26rpx; color: var(--text-secondary, #888); }
