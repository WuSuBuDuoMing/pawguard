.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }
.pet-picker { display: inline-flex; align-items: center; gap: 12rpx; padding: 14rpx 28rpx; border-radius: 24rpx; background: var(--card-bg); box-shadow: var(--shadow); font-size: 28rpx; color: var(--text-primary); margin-bottom: 28rpx; }

.score-card { display: flex; justify-content: space-between; align-items: center; background: var(--card-bg); border-radius: 28rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: var(--shadow); }
.score-card__left { display: flex; align-items: baseline; gap: 8rpx; }
.score-card__label { font-size: 26rpx; color: var(--text-secondary); margin-right: 12rpx; }
.score-card__score { font-size: 56rpx; font-weight: 700; }
.score-card__unit { font-size: 24rpx; color: var(--text-secondary); }
.score-card__right { display: flex; gap: 24rpx; }
.score-card__stat { text-align: center; }
.score-card__stat-num { font-size: 32rpx; font-weight: 700; display: block; }
.score-card__stat-label { font-size: 22rpx; color: var(--text-secondary); }

.alert-section { margin-bottom: 24rpx; }
.alert-section__title { font-size: 28rpx; font-weight: 600; color: #FF4D4F; margin-bottom: 12rpx; }
.alert-card { display: flex; align-items: flex-start; gap: 12rpx; padding: 16rpx 20rpx; background: rgba(255,77,79,0.06); border-radius: 16rpx; margin-bottom: 8rpx; border: 1rpx solid rgba(255,77,79,0.1); }
.alert-card__icon { font-size: 28rpx; flex-shrink: 0; margin-top: 4rpx; }
.alert-card__info { flex: 1; }
.alert-card__note { font-size: 24rpx; color: var(--text-primary); display: block; line-height: 1.5; }
.alert-card__date { font-size: 22rpx; color: var(--text-secondary); }
.alert-tip { padding: 12rpx 16rpx; background: rgba(250,173,20,0.06); border-radius: 12rpx; font-size: 22rpx; color: var(--text-secondary); }

.section { margin-bottom: 24rpx; }
.section__header { margin-bottom: 16rpx; }
.section__title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }

.quick-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.quick-item { width: calc(25% - 10rpx); display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; background: var(--card-bg); border-radius: 20rpx; box-shadow: var(--shadow); }
.quick-item:active { transform: scale(0.95); }
.quick-item__icon { font-size: 32rpx; margin-bottom: 8rpx; }
.quick-item__name { font-size: 22rpx; color: var(--text-primary); }

.record-list { }
.record-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 20rpx; background: var(--card-bg); border-radius: 16rpx; margin-bottom: 10rpx; box-shadow: var(--shadow); border-left: 6rpx solid transparent; }
.record-item.normal { border-left-color: #52C41A; }
.record-item.abnormal { border-left-color: #FF4D4F; }
.record-item__left { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.record-item__icon { font-size: 28rpx; }
.record-item__info { flex: 1; }
.record-item__note { font-size: 24rpx; color: var(--text-primary); display: block; }
.record-item__meta { font-size: 22rpx; color: var(--text-secondary); }
.record-item__badge { width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; }
.record-item__badge.normal { background: rgba(82,196,26,0.12); color: #52C41A; }
.record-item__badge.abnormal { background: rgba(255,77,79,0.12); color: #FF4D4F; }
.empty-hint { text-align: center; padding: 60rpx 0; font-size: 26rpx; color: var(--text-secondary); }

/* FAB */
.fab-btn {
  position: fixed; right: 40rpx; bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FF4D4F, #ff7875);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,77,79,0.4); z-index: 100;
  font-size: 40rpx;
}
.fab-btn:active { transform: scale(0.9); }

/* Modal */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; display: flex; align-items: flex-end; }
.modal-content {
  width: 100%; max-height: 85vh; background: var(--card-bg); border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid var(--border-color); }
.modal-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.modal-close { font-size: 32rpx; color: var(--text-secondary); padding: 8rpx; }
.modal-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; max-height: 60vh; }
.modal-footer { display: flex; gap: 16rpx; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.modal-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 30rpx; font-weight: 500; }
.modal-btn.cancel { background: var(--border-color); color: var(--text-secondary); }
.modal-btn.confirm { background: linear-gradient(135deg, #FF4D4F, #ff7875); color: #FFF; }

/* Form */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.form-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
}
.form-textarea {
  width: 100%; height: 200rpx; padding: 16rpx 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.abnormal-tip {
  padding: 16rpx 20rpx; border-radius: 16rpx;
  background: rgba(250,173,20,0.06); border: 1rpx solid rgba(250,173,20,0.12);
}
.abnormal-tip text { font-size: 22rpx; color: #996600; line-height: 1.5; }
