.page { padding: 24rpx 32rpx; min-height: 100vh; }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 32rpx; }
.pet-list { padding-bottom: 120rpx; }

.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.modal {
  width: 88%; max-height: 85vh; overflow-y: auto;
  background: var(--card-bg, #FFF); border-radius: 32rpx;
  padding: 40rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}
.modal__title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); display: block; text-align: center; margin-bottom: 32rpx; }
.modal__form { margin-bottom: 32rpx; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 24rpx; color: var(--text-secondary); display: block; margin-bottom: 8rpx; }
.form-input {
  width: 100%; padding: 16rpx 20rpx; border: 2rpx solid var(--border-color);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
  background: var(--bg-color); box-sizing: border-box;
}
.form-textarea { width: 100%; padding: 16rpx 20rpx; border: 2rpx solid var(--border-color); border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); background: var(--bg-color); height: 120rpx; box-sizing: border-box; }
.picker { color: var(--text-secondary); }
.form-radio-group { display: flex; gap: 16rpx; }
.form-radio {
  flex: 1; text-align: center; padding: 14rpx;
  border: 2rpx solid var(--border-color); border-radius: 16rpx;
  font-size: 26rpx; color: var(--text-primary);
}
.form-radio.active { border-color: #FF9F5A; background: rgba(255,159,90,0.08); color: #FF9F5A; }
.modal__actions { display: flex; gap: 20rpx; }
.modal__actions button { flex: 1; }

/* 性格标签选择器 */
.personality-picker { display: flex; flex-wrap: wrap; gap: 12rpx; }
.personality-tag {
  padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx;
  background: var(--bg-color); color: var(--text-secondary);
  border: 2rpx solid var(--border-color); transition: all 0.2s;
}
.personality-tag.selected {
  background: rgba(255,159,90,0.12); color: #FF9F5A;
  border-color: #FF9F5A;
}
