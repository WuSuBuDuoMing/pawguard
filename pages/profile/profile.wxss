.page { padding: 0 0 40rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }

/* 头部 */
.profile-header {
  position: relative; padding: 80rpx 40rpx 48rpx; margin-bottom: -20rpx;
}
.profile-header__bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #FF9F5A, #FFB87C, #FFC6A0);
  border-radius: 0 0 48rpx 48rpx;
}
.profile-header__content { position: relative; z-index: 1; display: flex; align-items: center; }
.profile-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.3); backdrop-filter: blur(10px);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; border: 4rpx solid rgba(255,255,255,0.5);
}
.profile-info { margin-left: 28rpx; }
.profile-name { font-size: 36rpx; font-weight: 700; color: #FFF; display: block; }
.profile-desc { font-size: 24rpx; color: rgba(255,255,255,0.85); }

/* 统计 */
.stats-grid {
  display: flex; justify-content: space-around;
  background: var(--card-bg); border-radius: 28rpx;
  padding: 32rpx; margin: 0 32rpx 28rpx; box-shadow: var(--shadow);
}
.stats-item { text-align: center; }
.stats-num { font-size: 44rpx; font-weight: 700; color: #FF9F5A; display: block; }
.stats-label { font-size: 22rpx; color: var(--text-secondary); }

/* 区块 */
.section { margin: 0 32rpx 24rpx; }
.card { background: var(--card-bg); border-radius: 28rpx; padding: 28rpx; box-shadow: var(--shadow); }
.section__header { margin-bottom: 20rpx; }
.section__title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }

/* 成就 */
.badges { display: flex; flex-wrap: wrap; gap: 16rpx; }
.badge {
  display: flex; flex-direction: column; align-items: center;
  width: calc(25% - 12rpx); padding: 20rpx 0;
  border-radius: 20rpx; transition: all 0.3s;
}
.badge.unlocked { background: rgba(255,159,90,0.08); }
.badge.locked { opacity: 0.35; }
.badge__icon { font-size: 40rpx; margin-bottom: 8rpx; }
.badge__name { font-size: 20rpx; color: var(--text-primary); text-align: center; }

/* 菜单 */
.menu-group {
  background: var(--card-bg); border-radius: 28rpx;
  margin: 0 32rpx 24rpx; overflow: hidden; box-shadow: var(--shadow);
}
.menu-item {
  display: flex; align-items: center; padding: 28rpx;
  border-bottom: 1rpx solid var(--border-color); transition: background 0.2s;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(255,159,90,0.04); }
.menu-item__icon { font-size: 32rpx; margin-right: 20rpx; }
.menu-item__name { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.menu-item__extra { font-size: 24rpx; color: var(--text-secondary); margin-right: 8rpx; }
.menu-item__badge {
  min-width: 32rpx; height: 32rpx; padding: 0 10rpx;
  background: #FF4D4F; color: #FFF; font-size: 20rpx;
  border-radius: 16rpx; display: flex; align-items: center;
  justify-content: center; margin-right: 8rpx;
}
.menu-item__arrow { font-size: 32rpx; color: var(--text-secondary); }

/* 底部 */
.footer { text-align: center; padding: 40rpx 0 20rpx; }
.footer__text { font-size: 24rpx; color: var(--text-secondary); opacity: 0.6; }
