.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }
.pet-picker { display: inline-flex; align-items: center; gap: 12rpx; padding: 14rpx 28rpx; border-radius: 24rpx; background: var(--card-bg); box-shadow: var(--shadow); font-size: 28rpx; color: var(--text-primary); margin-bottom: 28rpx; }

.summary-card { background: linear-gradient(135deg, rgba(126,200,227,0.1), rgba(255,181,194,0.1)); border-radius: 24rpx; padding: 28rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(126,200,227,0.12); }
.summary-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.summary-card__title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.summary-card__count { font-size: 24rpx; color: #FF9F5A; font-weight: 600; }
.summary-card__text { font-size: 24rpx; color: var(--text-secondary); line-height: 1.6; display: block; margin-bottom: 12rpx; }
.summary-card__moods { display: flex; gap: 4rpx; }
.mood-dot { font-size: 28rpx; }

.mood-calendar { background: var(--card-bg); border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: var(--shadow); }
.mood-calendar__header { margin-bottom: 16rpx; }
.mood-calendar__title { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.mood-calendar__grid { display: flex; flex-wrap: wrap; gap: 8rpx; }
.mood-calendar__day { width: calc(14.28% - 7rpx); aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 12rpx; }
.mood-calendar__day.has-entry { background: rgba(255,159,90,0.06); }
.mood-calendar__date { font-size: 20rpx; color: var(--text-secondary); }
.mood-calendar__emoji { font-size: 22rpx; }

.diary-list { padding-bottom: 20rpx; }

.ai-generate { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; background: linear-gradient(135deg, rgba(126,200,227,0.08), rgba(255,159,90,0.06)); border-radius: 20rpx; margin-top: 8rpx; border: 1rpx solid rgba(126,200,227,0.1); }
.ai-generate__icon { font-size: 36rpx; }
.ai-generate__info { flex: 1; }
.ai-generate__title { font-size: 28rpx; font-weight: 500; color: var(--text-primary); display: block; }
.ai-generate__desc { font-size: 22rpx; color: var(--text-secondary); }
.ai-generate__arrow { font-size: 32rpx; color: var(--text-secondary); }

.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.ai-modal { width: 88%; max-height: 80vh; overflow-y: auto; background: var(--card-bg); border-radius: 32rpx; padding: 40rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2); }
.ai-modal__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.ai-modal__badge { font-size: 24rpx; padding: 6rpx 16rpx; background: linear-gradient(135deg, rgba(126,200,227,0.15), rgba(255,159,90,0.15)); border-radius: 16rpx; color: var(--text-primary); }
.ai-modal__close { font-size: 28rpx; color: var(--text-secondary); padding: 8rpx; }
.ai-modal__title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 20rpx; }
.ai-modal__content { font-size: 28rpx; color: var(--text-primary); line-height: 1.8; display: block; margin-bottom: 20rpx; }
.ai-modal__mood { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 28rpx; }
.ai-modal__actions { display: flex; gap: 16rpx; }
.ai-modal__actions button { flex: 1; }

/* 写日记弹窗 */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; display: flex; align-items: flex-end; }
.modal-content {
  width: 100%; max-height: 85vh; background: var(--card-bg); border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid var(--border-color); }
.modal-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.modal-close { font-size: 32rpx; color: var(--text-secondary); padding: 8rpx; }
.modal-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; max-height: 60vh; }
.modal-footer { display: flex; gap: 16rpx; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.modal-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 30rpx; font-weight: 500; }
.modal-btn.cancel { background: var(--border-color); color: var(--text-secondary); }
.modal-btn.confirm { background: linear-gradient(135deg, #FFB5C2, #FF9BAD); color: #FFF; }

.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.form-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
}
.form-textarea {
  width: 100%; height: 120rpx; padding: 16rpx 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.diary-textarea { height: 300rpx; }
