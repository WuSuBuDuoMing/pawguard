<view class="page {{themeClass}}">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索宠物、日记、健康记录..." value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" focus="{{true}}" confirm-type="search" />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="onClear">✕</text>
    </view>
    <text class="search-cancel" bindtap="onCancel">取消</text>
  </view>

  <!-- 搜索历史 -->
  <view class="history" wx:if="{{!keyword && searchHistory.length > 0}}">
    <view class="history__header">
      <text class="history__title">搜索历史</text>
      <text class="history__clear" bindtap="clearHistory">清空</text>
    </view>
    <view class="history__tags">
      <view class="history__tag" wx:for="{{searchHistory}}" wx:key="*this" bindtap="onHistoryTap" data-word="{{item}}">{{item}}</view>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="hot" wx:if="{{!keyword}}">
    <text class="hot__title">🔥 热门搜索</text>
    <view class="hot__list">
      <view class="hot__item" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="onHistoryTap" data-word="{{item}}">
        <text class="hot__index {{index < 3 ? 'top' : ''}}">{{index + 1}}</text>
        <text class="hot__word">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="results" wx:if="{{keyword && searched}}">
    <!-- 分类标签 -->
    <scroll-view scroll-x class="results__tabs" enhanced show-scrollbar="{{false}}">
      <view class="results__tabs-inner">
        <view class="results__tab {{activeTab === '' ? 'active' : ''}}" bindtap="onTab" data-tab="">全部 ({{resultTotal}})</view>
        <view class="results__tab {{activeTab === 'pet' ? 'active' : ''}}" bindtap="onTab" data-tab="pet" wx:if="{{results.pets.length}}">🐾 {{results.pets.length}}</view>
        <view class="results__tab {{activeTab === 'diary' ? 'active' : ''}}" bindtap="onTab" data-tab="diary" wx:if="{{results.diaries.length}}">📝 {{results.diaries.length}}</view>
        <view class="results__tab {{activeTab === 'health' ? 'active' : ''}}" bindtap="onTab" data-tab="health" wx:if="{{results.health.length}}">💊 {{results.health.length}}</view>
        <view class="results__tab {{activeTab === 'feeding' ? 'active' : ''}}" bindtap="onTab" data-tab="feeding" wx:if="{{results.feeding.length}}">🍽️ {{results.feeding.length}}</view>
        <view class="results__tab {{activeTab === 'inventory' ? 'active' : ''}}" bindtap="onTab" data-tab="inventory" wx:if="{{results.inventory.length}}">📦 {{results.inventory.length}}</view>
        <view class="results__tab {{activeTab === 'expense' ? 'active' : ''}}" bindtap="onTab" data-tab="expense" wx:if="{{results.expenses.length}}">💰 {{results.expenses.length}}</view>
      </view>
    </scroll-view>

    <!-- 宠物结果 -->
    <view wx:if="{{activeTab === '' || activeTab === 'pet'}}">
      <view class="result-item" wx:for="{{results.pets}}" wx:key="id" bindtap="goPet" data-id="{{item.id}}">
        <text class="result-item__icon">{{item.species === 'dog' ? '🐶' : item.species === 'cat' ? '🐱' : item.species === 'rabbit' ? '🐰' : item.species === 'hamster' ? '🐹' : item.species === 'bird' ? '🐦' : item.species === 'reptile' ? '🦎' : '🐾'}}</text>
        <view class="result-item__info">
          <text class="result-item__title">{{item.name}}</text>
          <text class="result-item__desc">{{item.breed}} · {{item.personality ? item.personality.join('·') : ''}}</text>
        </view>
        <text class="result-item__tag tag tag-orange">宠物</text>
      </view>
    </view>

    <!-- 日记结果 -->
    <view wx:if="{{activeTab === '' || activeTab === 'diary'}}">
      <view class="result-item" wx:for="{{results.diaries}}" wx:key="id" bindtap="goDiary">
        <text class="result-item__icon">📝</text>
        <view class="result-item__info">
          <text class="result-item__title">{{item.title}}</text>
          <text class="result-item__desc">{{item.date}} · {{item.content}}</text>
        </view>
        <text class="result-item__tag tag tag-blue">日记</text>
      </view>
    </view>

    <!-- 健康结果 -->
    <view wx:if="{{activeTab === '' || activeTab === 'health'}}">
      <view class="result-item" wx:for="{{results.health}}" wx:key="id" bindtap="goHealth">
        <text class="result-item__icon">💊</text>
        <view class="result-item__info">
          <text class="result-item__title">{{item.title}}</text>
          <text class="result-item__desc">{{item.date}} · {{item.notes}}</text>
        </view>
        <text class="result-item__tag tag tag-pink">健康</text>
      </view>
    </view>

    <!-- 喂食结果 -->
    <view wx:if="{{activeTab === '' || activeTab === 'feeding'}}">
      <view class="result-item" wx:for="{{results.feeding}}" wx:key="id" bindtap="goFeeding">
        <text class="result-item__icon">🍽️</text>
        <view class="result-item__info">
          <text class="result-item__title">{{item.foodName}}</text>
          <text class="result-item__desc">{{item.petName}} · {{item.foodType}} · {{item.grams}}g · {{item.date}}</text>
        </view>
        <text class="result-item__tag tag tag-orange">喂食</text>
      </view>
    </view>

    <!-- 库存结果 -->
    <view wx:if="{{activeTab === '' || activeTab === 'inventory'}}">
      <view class="result-item" wx:for="{{results.inventory}}" wx:key="id" bindtap="goInventory">
        <text class="result-item__icon">📦</text>
        <view class="result-item__info">
          <text class="result-item__title">{{item.name}}</text>
          <text class="result-item__desc">{{item.type}} · 库存 {{item.currentStock}}{{item.unit}}</text>
        </view>
        <text class="result-item__tag tag tag-green">库存</text>
      </view>
    </view>

    <!-- 开销结果 -->
    <view wx:if="{{activeTab === '' || activeTab === 'expense'}}">
      <view class="result-item" wx:for="{{results.expenses}}" wx:key="id" bindtap="goExpense">
        <text class="result-item__icon">💰</text>
        <view class="result-item__info">
          <text class="result-item__title">{{item.title}}</text>
          <text class="result-item__desc">{{item.date}} · {{item.category}} · ¥{{item.amount}}</text>
        </view>
        <text class="result-item__tag tag tag-green">开销</text>
      </view>
    </view>

    <empty-state wx:if="{{resultTotal === 0}}" icon="🔍" title="没有找到相关内容" desc="换个关键词试试" />
  </view>
</view>
