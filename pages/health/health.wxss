.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }

.pet-picker { display: inline-flex; align-items: center; gap: 12rpx; padding: 14rpx 28rpx; border-radius: 24rpx; background: var(--card-bg); box-shadow: var(--shadow); font-size: 28rpx; color: var(--text-primary); margin-bottom: 28rpx; }

/* 总览网格 */
.summary-grid { display: flex; gap: 12rpx; margin-bottom: 28rpx; }
.summary-tile {
  flex: 1; background: var(--card-bg); border-radius: 20rpx;
  padding: 24rpx 16rpx; text-align: center; box-shadow: var(--shadow);
  position: relative; overflow: hidden;
}
.summary-tile__num { font-size: 40rpx; font-weight: 700; display: block; }
.summary-tile__label { font-size: 22rpx; color: var(--text-secondary); }
.summary-tile__dot { position: absolute; top: 0; right: 0; width: 8rpx; height: 100%; }

/* 体重卡片 */
.weight-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx; margin-bottom: 28rpx;
  background: linear-gradient(135deg, rgba(255,159,90,0.08), rgba(255,184,124,0.05));
  border: 1rpx solid rgba(255,159,90,0.12); border-radius: 20rpx;
}
.weight-card__left { display: flex; align-items: center; gap: 16rpx; }
.weight-card__icon { font-size: 36rpx; }
.weight-card__info {}
.weight-card__value { font-size: 36rpx; font-weight: 700; color: var(--text-primary); display: block; }
.weight-card__trend { font-size: 24rpx; color: var(--text-secondary); }
.weight-card__right {}
.weight-card__btn {
  padding: 10rpx 24rpx; border-radius: 20rpx;
  background: linear-gradient(135deg, #FF9F5A, #FFB87C);
  color: #FFF; font-size: 24rpx; font-weight: 500;
}
.weight-card__btn:active { opacity: 0.8; }

/* 体重趋势图 */
.weight-chart {
  margin-bottom: 28rpx; padding: 24rpx;
  background: var(--card-bg); border-radius: 20rpx; box-shadow: var(--shadow);
}
.weight-chart__header { margin-bottom: 12rpx; }
.weight-chart__title { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }

/* 提醒卡片 */
.reminder-cards { margin-bottom: 24rpx; }
.reminder-card { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx; border-radius: 16rpx; margin-bottom: 8rpx; }
.reminder-card.overdue { background: rgba(255,77,79,0.08); border: 1rpx solid rgba(255,77,79,0.15); }
.reminder-card.upcoming { background: rgba(250,173,20,0.06); border: 1rpx solid rgba(250,173,20,0.12); }
.reminder-card__icon { font-size: 28rpx; }
.reminder-card__info { flex: 1; }
.reminder-card__title { font-size: 24rpx; font-weight: 500; color: var(--text-primary); display: block; }
.reminder-card__date { font-size: 22rpx; color: var(--text-secondary); }

/* 筛选 */
.filter-scroll { margin-bottom: 24rpx; }
.filter-bar { display: flex; gap: 12rpx; }
.filter-chip { padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; background: var(--card-bg); color: var(--text-secondary); box-shadow: var(--shadow); white-space: nowrap; }
.filter-chip.active { background: #FF9F5A; color: #FFF; box-shadow: 0 4rpx 12rpx rgba(255,159,90,0.3); }

/* 时间线 */
.timeline { padding-left: 36rpx; }
.timeline__item { position: relative; padding-left: 32rpx; padding-bottom: 8rpx; }
.timeline__node { position: absolute; left: -18rpx; top: 28rpx; width: 16rpx; height: 16rpx; border-radius: 50%; z-index: 2; }
.timeline__line { position: absolute; left: -11rpx; top: 44rpx; bottom: 0; width: 2rpx; background: var(--border-color); z-index: 1; }
.timeline__card {
  background: var(--card-bg); border-radius: 20rpx;
  padding: 20rpx 24rpx; margin-bottom: 12rpx; box-shadow: var(--shadow);
}
.timeline__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.timeline__type-tag { padding: 4rpx 14rpx; border-radius: 14rpx; font-size: 20rpx; }
.timeline__date { font-size: 22rpx; color: var(--text-secondary); }
.timeline__title { font-size: 28rpx; font-weight: 500; color: var(--text-primary); display: block; margin-bottom: 6rpx; }
.timeline__clinic { font-size: 22rpx; color: var(--text-secondary); display: block; }
.timeline__notes { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; display: block; line-height: 1.5; }
.timeline__next { display: flex; align-items: center; gap: 8rpx; margin-top: 10rpx; flex-wrap: wrap; }
.timeline__next-label { font-size: 22rpx; color: var(--text-secondary); }
.timeline__next-date { font-size: 22rpx; font-weight: 500; }
.timeline__badge { font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 10rpx; }

/* 免责声明 */
.disclaimer {
  margin-top: 28rpx; padding: 20rpx 24rpx;
  background: rgba(250,173,20,0.06); border-radius: 16rpx;
  border: 1rpx solid rgba(250,173,20,0.1);
  margin-bottom: 120rpx;
}
.disclaimer text { font-size: 22rpx; color: var(--text-secondary); line-height: 1.6; }

/* FAB */
.fab-btn {
  position: fixed; right: 40rpx; bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FF9F5A, #FFB87C);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,159,90,0.4); z-index: 100;
  font-size: 48rpx; color: #FFF;
}
.fab-btn:active { transform: scale(0.9); }
