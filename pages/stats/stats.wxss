.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }

.range-picker { display: flex; background: var(--card-bg); border-radius: 20rpx; padding: 6rpx; margin-bottom: 24rpx; box-shadow: var(--shadow); }
.range-item { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 16rpx; font-size: 26rpx; color: var(--text-secondary); transition: all 0.3s; }
.range-item.active { background: #FF9F5A; color: #FFF; font-weight: 600; }

.overview-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.ov-card { width: calc(50% - 6rpx); background: var(--card-bg); border-radius: 20rpx; padding: 24rpx; box-shadow: var(--shadow); display: flex; flex-direction: column; align-items: center; }
.ov-card__icon { font-size: 32rpx; margin-bottom: 8rpx; }
.ov-card__num { font-size: 36rpx; font-weight: 700; color: #FF9F5A; }
.ov-card__label { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

.section { margin-bottom: 24rpx; }
.card { background: var(--card-bg); border-radius: 28rpx; padding: 28rpx; box-shadow: var(--shadow); }
.section__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section__title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.section__avg { font-size: 24rpx; color: #52C41A; font-weight: 600; }

.pet-expense-list { }
.pet-expense-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.pet-expense-row__left { display: flex; align-items: center; gap: 8rpx; min-width: 120rpx; }
.pet-expense-row__icon { font-size: 24rpx; }
.pet-expense-row__name { font-size: 24rpx; color: var(--text-primary); }
.pet-expense-row__bar-wrap { flex: 1; height: 20rpx; background: rgba(0,0,0,0.04); border-radius: 10rpx; overflow: hidden; }
.pet-expense-row__bar { height: 100%; border-radius: 10rpx; transition: width 0.8s ease; }
.pet-expense-row__amount { font-size: 24rpx; font-weight: 600; color: var(--text-primary); min-width: 100rpx; text-align: right; }

.health-overview { display: flex; justify-content: space-around; margin-bottom: 16rpx; }
.health-ov-item { text-align: center; }
.health-ov-item__icon { font-size: 28rpx; display: block; }
.health-ov-item__count { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; }
.health-ov-item__label { font-size: 20rpx; color: var(--text-secondary); }
.health-alert { padding: 14rpx 20rpx; background: rgba(250,173,20,0.08); border-radius: 12rpx; font-size: 24rpx; color: #FAAD14; }

.inv-health { display: flex; align-items: center; gap: 28rpx; }
.inv-health__ring { flex-shrink: 0; }
.inv-health__info { flex: 1; }
.inv-health__row { display: flex; justify-content: space-between; margin-bottom: 12rpx; font-size: 24rpx; color: var(--text-secondary); }
.inv-health__val { font-weight: 600; color: var(--text-primary); }
