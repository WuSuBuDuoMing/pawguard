.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }
.pet-picker { display: inline-flex; align-items: center; gap: 12rpx; padding: 14rpx 28rpx; border-radius: 24rpx; background: var(--card-bg); box-shadow: var(--shadow); font-size: 28rpx; color: var(--text-primary); margin-bottom: 28rpx; }

.stats-bar { margin-bottom: 24rpx; }
.stats-bar__count { font-size: 24rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx; }
.stats-bar__tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag.selected { background: #FF9F5A !important; color: #FFF !important; }

.album-section { margin-bottom: 28rpx; }
.album-section__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.album-section__date { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.album-section__count { font-size: 22rpx; color: var(--text-secondary); }

.photo-modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.photo-modal { width: 90%; max-height: 85vh; background: var(--card-bg); border-radius: 24rpx; overflow: hidden; }
.photo-modal__img { width: 100%; height: 500rpx; }
.photo-modal__info { padding: 24rpx; }
.photo-modal__title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 8rpx; }
.photo-modal__date { font-size: 24rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx; }
.photo-modal__tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
