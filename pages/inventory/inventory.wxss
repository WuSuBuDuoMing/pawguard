.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }

.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }

.mode-toggle {
  display: flex; background: var(--card-bg); border-radius: 20rpx;
  padding: 6rpx; margin-bottom: 24rpx; box-shadow: var(--shadow);
}
.mode-toggle__item {
  flex: 1; text-align: center; padding: 16rpx 0;
  border-radius: 16rpx; font-size: 26rpx; color: var(--text-secondary);
  transition: all 0.3s;
}
.mode-toggle__item.active { background: #FF9F5A; color: #FFF; font-weight: 600; }

.alert-bar { display: flex; align-items: center; gap: 10rpx; padding: 16rpx 24rpx; background: rgba(255,77,79,0.08); border-radius: 16rpx; margin-bottom: 20rpx; border: 1rpx solid rgba(255,77,79,0.12); }
.alert-bar__icon { font-size: 24rpx; }
.alert-bar__text { font-size: 24rpx; color: #FF4D4F; }

.filter-scroll { margin-bottom: 20rpx; }
.filter-bar { display: flex; gap: 12rpx; }
.filter-chip { display: inline-block; padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; background: var(--card-bg); color: var(--text-secondary); box-shadow: var(--shadow); white-space: nowrap; }
.filter-chip.active { background: #FF9F5A; color: #FFF; }

.inventory-summary { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.inventory-summary__text { font-size: 24rpx; color: var(--text-secondary); }
.inventory-summary__low { font-size: 24rpx; color: #FF4D4F; font-weight: 500; }
.inventory-list { padding-bottom: 40rpx; }

/* 购物清单 */
.shop-list { }
.shop-item { display: flex; align-items: center; gap: 16rpx; padding: 20rpx; background: var(--card-bg); border-radius: 16rpx; margin-bottom: 12rpx; box-shadow: var(--shadow); }
.shop-item__check { width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid #DDD; display: flex; align-items: center; justify-content: center; transition: all 0.3s; flex-shrink: 0; }
.shop-item__check.checked { background: #52C41A; border-color: #52C41A; color: #FFF; font-size: 22rpx; }
.shop-item__info { flex: 1; }
.shop-item__name { font-size: 26rpx; color: var(--text-primary); display: block; }
.shop-item__name.done { text-decoration: line-through; opacity: 0.5; }
.shop-item__brand { font-size: 22rpx; color: var(--text-secondary); }
.shop-item__price { font-size: 26rpx; font-weight: 600; color: #FF9F5A; }

.shop-total { display: flex; justify-content: flex-end; align-items: center; gap: 12rpx; padding: 24rpx; background: rgba(255,159,90,0.06); border-radius: 16rpx; margin-top: 16rpx; font-size: 28rpx; color: var(--text-primary); }
.shop-total__amount { font-size: 36rpx; font-weight: 700; color: #FF9F5A; }

/* FAB */
.fab-btn {
  position: fixed; right: 40rpx; bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FAAD14, #FFC53D);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(250,173,20,0.4); z-index: 100;
  font-size: 48rpx; color: #FFF;
}
.fab-btn:active { transform: scale(0.9); }

/* Modal */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; display: flex; align-items: flex-end; }
.modal-content {
  width: 100%; max-height: 85vh; background: var(--card-bg); border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid var(--border-color); }
.modal-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.modal-close { font-size: 32rpx; color: var(--text-secondary); padding: 8rpx; }
.modal-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; max-height: 60vh; }
.modal-footer { display: flex; gap: 16rpx; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.modal-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 30rpx; font-weight: 500; }
.modal-btn.cancel { background: var(--border-color); color: var(--text-secondary); }
.modal-btn.confirm { background: linear-gradient(135deg, #FAAD14, #FFC53D); color: #FFF; }

/* Form */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.form-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
}
.form-picker.placeholder { color: #CCC; }
