.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }

.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }

.pet-picker-wrap { margin-bottom: 28rpx; }
.pet-picker {
  display: inline-flex; align-items: center; gap: 12rpx;
  padding: 14rpx 28rpx; border-radius: 24rpx;
  background: var(--card-bg); box-shadow: var(--shadow);
  font-size: 28rpx; color: var(--text-primary);
}
.pet-picker__icon { font-size: 32rpx; }
.pet-picker__name { font-weight: 500; }
.pet-picker__arrow { font-size: 20rpx; color: var(--text-secondary); margin-left: 4rpx; }

/* 周日历 */
.week-calendar { display: flex; gap: 8rpx; margin-bottom: 24rpx; background: var(--card-bg); border-radius: 20rpx; padding: 16rpx; box-shadow: var(--shadow); }
.week-calendar__day { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 12rpx 0; border-radius: 16rpx; transition: all 0.2s; }
.week-calendar__day.today { background: rgba(255,159,90,0.1); }
.week-calendar__day.past { opacity: 0.6; }
.week-calendar__label { font-size: 20rpx; color: var(--text-secondary); }
.week-calendar__date { font-size: 28rpx; font-weight: 600; color: var(--text-primary); margin: 4rpx 0; }
.week-calendar__day.today .week-calendar__date { color: #FF9F5A; }
.week-calendar__dot { width: 10rpx; height: 10rpx; border-radius: 50%; margin-top: 4rpx; }
.week-calendar__dot.good { background: #52C41A; }
.week-calendar__dot.ok { background: #FAAD14; }
.week-calendar__dot.low { background: #FF4D4F; }

/* 庆祝动画 */
.celebrate {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%) scale(0);
  z-index: 999; display: flex; flex-direction: column; align-items: center;
  background: var(--card-bg); border-radius: 32rpx; padding: 60rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2); opacity: 0;
  transition: all 0.5s cubic-bezier(0.34,1.56,0.64,1);
  pointer-events: none;
}
.celebrate.show { transform: translate(-50%,-50%) scale(1); opacity: 1; pointer-events: auto; }
.celebrate__emoji { font-size: 80rpx; margin-bottom: 16rpx; animation: celebrateBounce 0.6s ease infinite alternate; }
.celebrate__text { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
@keyframes celebrateBounce { from { transform: scale(1); } to { transform: scale(1.15); } }

/* 区块 */
.section { margin-bottom: 28rpx; }
.card { background: var(--card-bg); border-radius: 28rpx; padding: 28rpx; box-shadow: var(--shadow); }
.section__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section__title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.section__count { font-size: 28rpx; font-weight: 600; color: #FF9F5A; }

/* 本周概览 */
.week-overview { display: flex; align-items: center; gap: 24rpx; }
.week-overview__ring { flex-shrink: 0; }
.week-overview__days { flex: 1; display: flex; gap: 10rpx; height: 120rpx; align-items: flex-end; }
.day-col { display: flex; flex-direction: column; align-items: center; flex: 1; height: 100%; justify-content: flex-end; }
.day-col__bar-wrap { flex: 1; width: 100%; display: flex; align-items: flex-end; justify-content: center; }
.day-col__bar { width: 28rpx; border-radius: 14rpx; min-height: 8rpx; transition: height 0.6s ease; }
.day-col__label { font-size: 20rpx; color: var(--text-secondary); margin-top: 6rpx; }

/* AI 建议 */
.ai-card {
  display: flex; align-items: flex-start; gap: 16rpx;
  background: linear-gradient(135deg, rgba(126,200,227,0.08), rgba(255,159,90,0.08));
  border-radius: 20rpx; padding: 24rpx; margin-bottom: 28rpx;
  border: 1rpx solid rgba(126,200,227,0.12);
}
.ai-card__icon-wrap { font-size: 36rpx; flex-shrink: 0; }
.ai-card__text { font-size: 26rpx; color: var(--text-primary); line-height: 1.6; }

/* 任务列表 */
.task-list { }

/* 完成统计 */
.done-summary {
  display: flex; align-items: center; gap: 12rpx;
}
.done-summary__icon { font-size: 32rpx; }
.done-summary__text { font-size: 26rpx; color: var(--text-primary); line-height: 1.6; }
