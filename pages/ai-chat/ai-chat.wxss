/* AI 聊天页面样式 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-color, #FFF8F0);
}

/* 顶部栏 */
.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--card-bg, #FFFFFF);
  border-bottom: 1rpx solid var(--border-color, #EEEEEE);
  position: sticky;
  top: 0;
  z-index: 10;
}
.chat-header__left { display: flex; align-items: center; }
.chat-header__avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7EC8E3, #5BA8C8);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; box-shadow: 0 4rpx 12rpx rgba(126,200,227,0.3);
}
.chat-header__info { margin-left: 16rpx; }
.chat-header__name { font-size: 30rpx; font-weight: 600; color: var(--text-primary, #333); display: block; }
.chat-header__status { font-size: 22rpx; color: #52C41A; }
.chat-header__right { display: flex; align-items: center; gap: 16rpx; }
.chat-header__pet {
  display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 16rpx; border-radius: 20rpx;
  background: rgba(126,200,227,0.1); font-size: 24rpx;
  color: var(--text-primary, #333);
}
.chat-header__arrow { font-size: 20rpx; opacity: 0.6; }
.chat-header__action { font-size: 32rpx; padding: 8rpx; }

/* 免责声明 */
.disclaimer-bar {
  display: flex; align-items: center; padding: 12rpx 24rpx;
  background: rgba(250,173,20,0.08); border-bottom: 1rpx solid rgba(250,173,20,0.15);
}
.disclaimer-bar__icon { margin-right: 8rpx; font-size: 24rpx; flex-shrink: 0; }
.disclaimer-bar__text { flex: 1; font-size: 22rpx; color: #996600; line-height: 1.4; }
.disclaimer-bar__close { padding: 4rpx 8rpx; font-size: 24rpx; color: #996600; }

/* 每日提示 */
.daily-tip {
  display: flex; align-items: flex-start; padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(126,200,227,0.08), rgba(82,196,26,0.06));
  border-bottom: 1rpx solid rgba(126,200,227,0.1);
}
.daily-tip__icon { margin-right: 10rpx; font-size: 26rpx; flex-shrink: 0; margin-top: 2rpx; }
.daily-tip__text { font-size: 24rpx; color: var(--text-secondary, #666); line-height: 1.5; }

/* 消息列表 */
.chat-messages {
  flex: 1;
  padding: 0 24rpx;
  overflow-y: auto;
}
.messages-inner { padding: 16rpx 0; }

/* 时间戳 */
.msg-time {
  text-align: center; padding: 16rpx 0;
}
.msg-time text {
  font-size: 20rpx; color: var(--text-secondary, #999);
  background: var(--bg-color, #FFF8F0); padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

/* 消息行 */
.msg-row {
  display: flex; align-items: flex-start; margin-bottom: 24rpx;
  animation: msgIn 0.3s ease-out both;
}
@keyframes msgIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.msg-row.user { flex-direction: row-reverse; }
.msg-row.assistant { flex-direction: row; }

/* 头像 */
.msg-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; flex-shrink: 0;
}
.user-avatar { background: linear-gradient(135deg, #FFB87C, #FF9F5A); margin-left: 12rpx; }
.assistant-avatar { background: linear-gradient(135deg, #7EC8E3, #5BA8C8); margin-right: 12rpx; }

/* 气泡 */
.msg-bubble {
  max-width: 75%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  position: relative;
  word-break: break-all;
}
.user-bubble {
  background: linear-gradient(135deg, #FF9F5A, #FFB87C);
  border-top-right-radius: 8rpx;
  color: #FFFFFF;
}
.assistant-bubble {
  background: var(--card-bg, #FFFFFF);
  border-top-left-radius: 8rpx;
  color: var(--text-primary, #333);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.urgent-bubble {
  background: rgba(255,77,79,0.06);
  border: 1rpx solid rgba(255,77,79,0.2);
  border-top-left-radius: 8rpx;
  color: var(--text-primary, #333);
}

.msg-urgent-badge {
  display: inline-flex; align-items: center;
  background: rgba(255,77,79,0.12); color: #FF4D4F;
  font-size: 22rpx; font-weight: 600;
  padding: 4rpx 12rpx; border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

/* 打字指示器 */
.typing-bubble { padding: 24rpx 32rpx; }
.typing-dots { display: flex; gap: 10rpx; }
.typing-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #7EC8E3;
  animation: typingBounce 1.2s infinite ease-in-out;
}
.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 快捷问题 */
.quick-questions {
  padding: 12rpx 0;
  border-top: 1rpx solid var(--border-color, #EEEEEE);
}
.quick-questions__inner {
  display: flex; gap: 12rpx; padding: 8rpx 24rpx;
}
.quick-q {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 20rpx; border-radius: 32rpx;
  background: var(--card-bg, #FFFFFF);
  border: 1rpx solid rgba(126,200,227,0.2);
  white-space: nowrap; transition: all 0.2s;
}
.quick-q:active { transform: scale(0.95); background: rgba(126,200,227,0.1); }
.quick-q__icon { font-size: 24rpx; }
.quick-q__text { font-size: 24rpx; color: var(--text-primary, #333); }

/* 输入区 */
.chat-input-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--card-bg, #FFFFFF);
  border-top: 1rpx solid var(--border-color, #EEEEEE);
}
.input-wrap {
  flex: 1; display: flex; align-items: center;
  background: var(--bg-color, #FFF8F0);
  border: 2rpx solid var(--border-color, #EEEEEE);
  border-radius: 40rpx;
  padding: 0 24rpx;
  transition: border-color 0.3s;
}
.input-wrap.focused { border-color: #7EC8E3; }
.chat-input {
  flex: 1; height: 80rpx; font-size: 28rpx;
  color: var(--text-primary, #333);
}
.input-placeholder { color: #CCCCCC; }
.send-btn {
  padding: 16rpx 28rpx; border-radius: 40rpx;
  background: #CCCCCC; color: #FFFFFF;
  font-size: 28rpx; font-weight: 500;
  transition: all 0.3s;
}
.send-btn.active {
  background: linear-gradient(135deg, #7EC8E3, #5BA8C8);
  box-shadow: 0 4rpx 12rpx rgba(126,200,227,0.3);
}
.send-btn:active { transform: scale(0.95); }
