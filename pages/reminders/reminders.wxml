<view class="page {{themeClass}}">
  <view class="page-title fade-in">🔔 提醒中心</view>

  <!-- 统计 -->
  <view class="stats fade-in" style="animation-delay:0.05s;">
    <view class="stats__item urgent">
      <text class="stats__num">{{urgentCount}}</text>
      <text class="stats__label">紧急</text>
    </view>
    <view class="stats__item warning">
      <text class="stats__num">{{warningCount}}</text>
      <text class="stats__label">即将到期</text>
    </view>
    <view class="stats__item normal">
      <text class="stats__num">{{normalCount}}</text>
      <text class="stats__label">待处理</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view scroll-x class="filter-scroll fade-in" style="animation-delay:0.08s;" enhanced show-scrollbar="{{false}}">
    <view class="filter-bar">
      <view class="filter-chip {{activeFilter === '' ? 'active' : ''}}" bindtap="onFilter" data-type="">全部</view>
      <view class="filter-chip {{activeFilter === 'health' ? 'active' : ''}}" bindtap="onFilter" data-type="health">💊 健康</view>
      <view class="filter-chip {{activeFilter === 'care' ? 'active' : ''}}" bindtap="onFilter" data-type="care">📋 照护</view>
      <view class="filter-chip {{activeFilter === 'feeding' ? 'active' : ''}}" bindtap="onFilter" data-type="feeding">🍽️ 喂食</view>
      <view class="filter-chip {{activeFilter === 'water' ? 'active' : ''}}" bindtap="onFilter" data-type="water">💧 饮水</view>
      <view class="filter-chip {{activeFilter === 'inventory' ? 'active' : ''}}" bindtap="onFilter" data-type="inventory">📦 库存</view>
    </view>
  </scroll-view>

  <!-- 提醒列表 -->
  <view class="reminder-list fade-in" style="animation-delay:0.12s;">
    <view class="reminder-card {{item.level}}" wx:for="{{filteredReminders}}" wx:key="id" bindtap="onReminderTap" data-reminder="{{item}}">
      <view class="reminder-card__left">
        <text class="reminder-card__icon">{{item.icon}}</text>
        <view class="reminder-card__info">
          <text class="reminder-card__title">{{item.title}}</text>
          <text class="reminder-card__desc">{{item.petName}} · {{item.detail}}</text>
        </view>
      </view>
      <view class="reminder-card__right">
        <text class="reminder-card__date">{{item.dateLabel}}</text>
        <view class="reminder-card__badge {{item.level}}">
          <text>{{item.levelLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{filteredReminders.length === 0}}" icon="🎉" title="没有待处理提醒" desc="一切都安排得妥妥的~" />
</view>
