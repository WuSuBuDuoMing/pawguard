.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 28rpx; }

.stats { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.stats__item { flex: 1; background: var(--card-bg); border-radius: 20rpx; padding: 24rpx; text-align: center; box-shadow: var(--shadow); position: relative; overflow: hidden; }
.stats__item::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 6rpx; }
.stats__item.urgent::before { background: #FF4D4F; }
.stats__item.warning::before { background: #FAAD14; }
.stats__item.normal::before { background: #7EC8E3; }
.stats__num { font-size: 44rpx; font-weight: 700; display: block; }
.stats__item.urgent .stats__num { color: #FF4D4F; }
.stats__item.warning .stats__num { color: #FAAD14; }
.stats__item.normal .stats__num { color: #7EC8E3; }
.stats__label { font-size: 22rpx; color: var(--text-secondary); }

.filter-scroll { margin-bottom: 20rpx; }
.filter-bar { display: flex; gap: 12rpx; }
.filter-chip { padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; background: var(--card-bg); color: var(--text-secondary); box-shadow: var(--shadow); white-space: nowrap; }
.filter-chip.active { background: #FF9F5A; color: #FFF; }

.reminder-list { }
.reminder-card {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx; background: var(--card-bg); border-radius: 20rpx;
  margin-bottom: 12rpx; box-shadow: var(--shadow);
  border-left: 6rpx solid transparent;
}
.reminder-card.urgent { border-left-color: #FF4D4F; }
.reminder-card.warning { border-left-color: #FAAD14; }
.reminder-card.normal { border-left-color: #7EC8E3; }

.reminder-card__left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.reminder-card__icon { font-size: 32rpx; }
.reminder-card__info { flex: 1; }
.reminder-card__title { font-size: 26rpx; font-weight: 500; color: var(--text-primary); display: block; }
.reminder-card__desc { font-size: 22rpx; color: var(--text-secondary); }

.reminder-card__right { text-align: right; }
.reminder-card__date { font-size: 22rpx; color: var(--text-secondary); display: block; margin-bottom: 6rpx; }
.reminder-card__badge { padding: 4rpx 14rpx; border-radius: 12rpx; font-size: 20rpx; display: inline-block; }
.reminder-card__badge.urgent { background: rgba(255,77,79,0.1); color: #FF4D4F; }
.reminder-card__badge.warning { background: rgba(250,173,20,0.1); color: #FAAD14; }
.reminder-card__badge.normal { background: rgba(126,200,227,0.1); color: #7EC8E3; }
