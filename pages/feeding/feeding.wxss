.page { padding: 24rpx 32rpx; min-height: 100vh; }
.page-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 20rpx; }

/* 入场动画 */
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(30rpx); } to { opacity: 1; transform: translateY(0); } }

/* 宠物选择器 */
.pet-picker {
  display: inline-flex; align-items: center; gap: 10rpx;
  padding: 12rpx 24rpx; border-radius: 24rpx;
  background: var(--card-bg); box-shadow: var(--shadow);
  font-size: 28rpx; color: var(--text-primary); margin-bottom: 20rpx;
}

/* 概览卡片 */
.overview-cards { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.ov-card {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 12rpx; border-radius: 20rpx;
  background: var(--card-bg); box-shadow: var(--shadow);
}
.ov-card__icon { font-size: 32rpx; margin-bottom: 6rpx; }
.ov-card__num { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.ov-card__label { font-size: 20rpx; color: var(--text-secondary); margin-top: 4rpx; }

/* Tab 切换 */
.tabs { display: flex; gap: 0; margin-bottom: 20rpx; background: var(--card-bg); border-radius: 16rpx; padding: 4rpx; box-shadow: var(--shadow); }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: var(--text-secondary); border-radius: 12rpx; transition: all 0.3s; }
.tab.active { background: linear-gradient(135deg, #FF9F5A, #FFB87C); color: #FFF; font-weight: 600; }

/* 快捷喂食 */
.quick-food { margin-bottom: 20rpx; }
.quick-food__title { font-size: 26rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; display: block; }
.quick-food__grid { display: flex; gap: 12rpx; }
.quick-food__btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 12rpx; border-radius: 20rpx;
  background: var(--card-bg); box-shadow: var(--shadow);
  transition: transform 0.2s;
}
.quick-food__btn:active { transform: scale(0.95); background: rgba(255,159,90,0.08); }
.quick-food__icon { font-size: 32rpx; margin-bottom: 6rpx; }
.quick-food__label { font-size: 22rpx; color: var(--text-primary); font-weight: 500; }

/* 喂食列表 */
.feeding-list { margin-bottom: 120rpx; }
.feeding-card { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.feeding-card__time-col { display: flex; flex-direction: column; align-items: center; width: 80rpx; flex-shrink: 0; }
.feeding-card__time { font-size: 24rpx; color: var(--text-secondary); font-weight: 500; }
.feeding-card__dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-top: 8rpx; }
.feeding-card__dot.done { background: #52C41A; }
.feeding-card__dot.skip { background: #DDD; }

.feeding-card__content {
  flex: 1; padding: 16rpx 20rpx; border-radius: 16rpx;
  background: var(--card-bg); box-shadow: var(--shadow);
}
.feeding-card__header { display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx; }
.feeding-card__name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.feeding-card__type-tag {
  font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 8rpx;
  background: rgba(255,159,90,0.1); color: #FF9F5A;
}
.feeding-card__detail { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.feeding-card__grams { font-size: 24rpx; color: var(--text-primary); font-weight: 500; }
.feeding-card__appetite { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }
.feeding-card__appetite.good { background: rgba(82,196,26,0.1); color: #52C41A; }
.feeding-card__appetite.warn { background: rgba(250,173,20,0.1); color: #FAAD14; }
.feeding-card__appetite.bad { background: rgba(255,77,79,0.1); color: #FF4D4F; }
.feeding-card__finished { font-size: 22rpx; color: var(--text-secondary); }
.feeding-card__notes { font-size: 22rpx; color: var(--text-secondary); margin-top: 8rpx; font-style: italic; }

/* 历史记录 */
.history-list { margin-bottom: 120rpx; }
.history-card {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 20rpx; margin-bottom: 12rpx;
  border-radius: 16rpx; background: var(--card-bg); box-shadow: var(--shadow);
}
.history-card__left { width: 120rpx; flex-shrink: 0; }
.history-card__date { font-size: 22rpx; color: var(--text-secondary); display: block; }
.history-card__time { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.history-card__center { flex: 1; }
.history-card__name { font-size: 26rpx; font-weight: 500; color: var(--text-primary); display: block; }
.history-card__meta { font-size: 22rpx; color: var(--text-secondary); }
.history-card__right { flex-shrink: 0; }
.history-card__appetite-badge { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.history-card__appetite-badge.good { background: rgba(82,196,26,0.1); color: #52C41A; }
.history-card__appetite-badge.warn { background: rgba(250,173,20,0.1); color: #FAAD14; }
.history-card__appetite-badge.bad { background: rgba(255,77,79,0.1); color: #FF4D4F; }

/* 数据统计 */
.section { margin-bottom: 24rpx; }
.card { background: var(--card-bg); border-radius: 24rpx; padding: 24rpx; box-shadow: var(--shadow); }
.section__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section__title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.no-data-hint { text-align: center; padding: 40rpx 0; font-size: 24rpx; color: var(--text-secondary); }

/* 食物分布 */
.food-dist-item { margin-bottom: 16rpx; }
.food-dist-item__header { display: flex; justify-content: space-between; margin-bottom: 6rpx; }
.food-dist-item__name { font-size: 24rpx; color: var(--text-primary); }
.food-dist-item__grams { font-size: 24rpx; color: var(--text-secondary); }
.food-dist-item__bar-wrap { height: 16rpx; background: var(--border-color, #EEE); border-radius: 8rpx; overflow: hidden; }
.food-dist-item__bar { height: 100%; border-radius: 8rpx; transition: width 0.6s ease; }

/* FAB */
.fab-btn {
  position: fixed; right: 40rpx; bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FF9F5A, #FFB87C);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,159,90,0.4); z-index: 100;
  font-size: 48rpx; color: #FFF;
}
.fab-btn:active { transform: scale(0.9); }

/* Modal */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; display: flex; align-items: flex-end; }
.modal-content {
  width: 100%; max-height: 85vh; background: var(--card-bg); border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid var(--border-color); }
.modal-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.modal-close { font-size: 32rpx; color: var(--text-secondary); padding: 8rpx; }
.modal-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; max-height: 60vh; }
.modal-footer { display: flex; gap: 16rpx; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.modal-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 30rpx; font-weight: 500; }
.modal-btn.cancel { background: var(--border-color); color: var(--text-secondary); }
.modal-btn.confirm { background: linear-gradient(135deg, #FF9F5A, #FFB87C); color: #FFF; }

/* 表单 */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
  box-sizing: border-box;
}
.form-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
}
.form-textarea {
  width: 100%; height: 120rpx; padding: 16rpx 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
  box-sizing: border-box;
}
