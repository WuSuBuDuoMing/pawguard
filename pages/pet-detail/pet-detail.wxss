.page { padding: 0 0 40rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }

.pet-header { position: relative; padding: 60rpx 40rpx 40rpx; margin-bottom: -20rpx; }
.pet-header__bg { position: absolute; inset: 0; border-radius: 0 0 48rpx 48rpx; }
.pet-header__bg.cat { background: linear-gradient(135deg, #FF9F5A, #FFB87C, #FFC6A0); }
.pet-header__bg.dog { background: linear-gradient(135deg, #7EC8E3, #5BA4C9, #a8dcf0); }
.pet-header__bg.rabbit { background: linear-gradient(135deg, #FFB5C2, #FF9BAD, #ffd1d9); }
.pet-header__bg.hamster { background: linear-gradient(135deg, #FAAD14, #FFC53D, #ffe08a); }
.pet-header__bg.bird { background: linear-gradient(135deg, #52C41A, #73d13d, #b7eb8f); }
.pet-header__bg.reptile { background: linear-gradient(135deg, #9B59B6, #8E44AD, #c39bd3); }
.pet-header__bg.other { background: linear-gradient(135deg, #3498DB, #2980B9, #85c1e9); }
.pet-header__content { position: relative; z-index: 1; text-align: center; }
.pet-header__avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25); display: inline-flex;
  align-items: center; justify-content: center; font-size: 56rpx;
  border: 4rpx solid rgba(255,255,255,0.4); margin-bottom: 12rpx;
}
.pet-header__name { font-size: 40rpx; font-weight: 700; color: #FFF; display: block; }
.pet-header__breed { font-size: 24rpx; color: rgba(255,255,255,0.85); display: block; margin-top: 6rpx; }
.pet-header__tags { display: flex; justify-content: center; gap: 10rpx; margin-top: 16rpx; }
.pet-header__edit { position: absolute; top: 40rpx; right: 32rpx; z-index: 2; font-size: 32rpx; padding: 12rpx; }

.stats-row { display: flex; gap: 12rpx; padding: 0 32rpx; margin-bottom: 20rpx; }
.stat-card {
  flex: 1; background: var(--card-bg); border-radius: 20rpx;
  padding: 20rpx 12rpx; text-align: center; box-shadow: var(--shadow);
}
.stat-card__num { font-size: 32rpx; font-weight: 700; display: block; }
.stat-card__unit { font-size: 20rpx; color: var(--text-secondary); }
.stat-card__label { font-size: 20rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }

.note-card { display: flex; align-items: flex-start; gap: 12rpx; margin: 0 32rpx 20rpx; padding: 20rpx 24rpx; background: rgba(250,173,20,0.06); border-radius: 16rpx; border: 1rpx solid rgba(250,173,20,0.1); }
.note-card__icon { font-size: 24rpx; flex-shrink: 0; }
.note-card__text { font-size: 24rpx; color: var(--text-secondary); line-height: 1.6; }

.tabs { padding: 0 32rpx; }
.tabs__nav { display: flex; gap: 4rpx; margin-bottom: 20rpx; background: var(--card-bg); border-radius: 20rpx; padding: 6rpx; box-shadow: var(--shadow); overflow-x: auto; white-space: nowrap; }
.tabs__item { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 16rpx; font-size: 22rpx; color: var(--text-secondary); transition: all 0.3s; min-width: 0; }
.tabs__item.active { background: #FF9F5A; color: #FFF; font-weight: 600; }

.reminder-banner { padding: 14rpx 20rpx; background: rgba(250,173,20,0.1); border-radius: 12rpx; margin-bottom: 16rpx; font-size: 24rpx; color: #FAAD14; }

.skill-summary { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.skill-pill { display: flex; align-items: center; gap: 8rpx; padding: 10rpx 20rpx; background: var(--card-bg); border-radius: 20rpx; box-shadow: var(--shadow); }
.skill-pill__name { font-size: 24rpx; color: var(--text-primary); }
.skill-pill__rate { font-size: 24rpx; font-weight: 600; color: #FF9F5A; }

.expense-total-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 20rpx; background: rgba(255,159,90,0.08); border-radius: 12rpx; margin-bottom: 16rpx; font-size: 26rpx; color: var(--text-primary); }
.expense-total-bar__amount { font-weight: 700; color: #FF9F5A; font-size: 30rpx; }

.expense-mini { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--border-color); }
.expense-mini:last-child { border-bottom: none; }
.expense-mini__title { flex: 1; font-size: 26rpx; color: var(--text-primary); }
.expense-mini__cat { font-size: 22rpx; color: var(--text-secondary); }
.expense-mini__date { font-size: 22rpx; color: var(--text-secondary); }
.expense-mini__amount { font-size: 26rpx; font-weight: 600; color: #FF9F5A; }

.diary-mini { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--border-color); }
.diary-mini:last-child { border-bottom: none; }
.diary-mini__mood { font-size: 32rpx; }
.diary-mini__info { flex: 1; }
.diary-mini__title { font-size: 26rpx; font-weight: 500; color: var(--text-primary); display: block; }
.diary-mini__date { font-size: 22rpx; color: var(--text-secondary); }

.empty-hint { text-align: center; padding: 60rpx 0; font-size: 26rpx; color: var(--text-secondary); }

/* 体重目标 */
.weight-goal { margin-top: 16rpx; padding: 16rpx 20rpx; background: rgba(255,159,90,0.06); border-radius: 16rpx; }
.weight-goal__label { font-size: 24rpx; font-weight: 500; color: var(--text-primary); display: block; margin-bottom: 12rpx; }
.weight-goal__progress { display: flex; align-items: center; gap: 12rpx; }
.weight-goal__bar { flex: 1; height: 12rpx; background: rgba(255,159,90,0.12); border-radius: 6rpx; overflow: hidden; }
.weight-goal__bar-fill { height: 100%; background: linear-gradient(90deg, #FF9F5A, #FFB87C); border-radius: 6rpx; transition: width 0.8s; }
.weight-goal__text { font-size: 22rpx; color: #FF9F5A; font-weight: 600; white-space: nowrap; }
.weight-goal-set { margin-top: 16rpx; padding: 16rpx; text-align: center; background: rgba(255,159,90,0.04); border-radius: 16rpx; font-size: 24rpx; color: var(--text-secondary); border: 2rpx dashed rgba(255,159,90,0.2); }

/* 活动时间线 */
.activity-timeline { padding-left: 16rpx; }
.activity-item { position: relative; padding-left: 28rpx; padding-bottom: 4rpx; }
.activity-item__dot { position: absolute; left: 0; top: 20rpx; width: 14rpx; height: 14rpx; border-radius: 50%; z-index: 2; }
.activity-item__line { position: absolute; left: 6rpx; top: 34rpx; bottom: 0; width: 2rpx; background: var(--border-color); z-index: 1; }
.activity-item__content { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; }
.activity-item__icon { font-size: 24rpx; }
.activity-item__info { flex: 1; }
.activity-item__title { font-size: 24rpx; color: var(--text-primary); display: block; }
.activity-item__date { font-size: 22rpx; color: var(--text-secondary); }

/* 喂食记录 mini */
.feeding-mini-list { margin-bottom: 16rpx; }
.feeding-mini {
  display: flex; align-items: center; gap: 16rpx;
  padding: 14rpx 0; border-bottom: 1rpx solid var(--border-color);
}
.feeding-mini:last-child { border-bottom: none; }
.feeding-mini__left { width: 100rpx; flex-shrink: 0; }
.feeding-mini__time { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; }
.feeding-mini__date { font-size: 20rpx; color: var(--text-secondary); }
.feeding-mini__center { flex: 1; }
.feeding-mini__name { font-size: 26rpx; font-weight: 500; color: var(--text-primary); display: block; }
.feeding-mini__meta { font-size: 22rpx; color: var(--text-secondary); }
.feeding-mini__right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.feeding-mini__appetite { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }
.feeding-mini__appetite.good { background: rgba(82,196,26,0.1); color: #52C41A; }
.feeding-mini__appetite.warn { background: rgba(250,173,20,0.1); color: #FAAD14; }
.feeding-mini__appetite.bad { background: rgba(255,77,79,0.1); color: #FF4D4F; }
.feeding-mini__finished { font-size: 22rpx; }

/* 饮水记录 mini */
.water-mini-list { margin-bottom: 16rpx; }
.water-mini {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 0; border-bottom: 1rpx solid var(--border-color);
}
.water-mini:last-child { border-bottom: none; }
.water-mini__date { font-size: 24rpx; color: var(--text-primary); font-weight: 500; width: 100rpx; flex-shrink: 0; }
.water-mini__bar-wrap { flex: 1; height: 16rpx; background: rgba(126,200,227,0.1); border-radius: 8rpx; overflow: hidden; }
.water-mini__bar { height: 100%; border-radius: 8rpx; transition: width 0.6s ease; }
.water-mini__amount { font-size: 24rpx; font-weight: 600; color: var(--text-primary); width: 100rpx; text-align: right; }
.water-mini__changes { font-size: 22rpx; color: var(--text-secondary); width: 100rpx; text-align: right; }

/* 更多链接 */
.more-link {
  text-align: center; padding: 20rpx 0; font-size: 24rpx;
  color: #FF9F5A; font-weight: 500;
}
.more-link:active { opacity: 0.7; }
