.page { padding: 24rpx 32rpx; min-height: 100vh; padding-bottom: 160rpx; }
.page-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }

.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(30rpx); } to { opacity: 1; transform: translateY(0); } }

/* 表单区块 */
.form-section { margin-bottom: 24rpx; }
.form-section__label { font-size: 26rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; display: block; }
.form-section__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.form-section__arrow { font-size: 24rpx; color: var(--text-secondary); }

/* 类型选择 */
.type-selector { margin-bottom: 24rpx; }
.type-grid { display: flex; gap: 12rpx; }
.type-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 8rpx; border-radius: 16rpx;
  background: var(--card-bg); box-shadow: var(--shadow);
  transition: all 0.3s;
}
.type-item.active {
  background: linear-gradient(135deg, rgba(126,200,227,0.2), rgba(126,200,227,0.1));
  border: 2rpx solid #7EC8E3;
}
.type-item__icon { font-size: 28rpx; margin-bottom: 4rpx; }
.type-item__name { font-size: 22rpx; color: var(--text-primary); }

/* 快捷模板 */
.template-grid { display: flex; flex-wrap: wrap; gap: 10rpx; }
.template-chip {
  padding: 10rpx 20rpx; border-radius: 20rpx;
  background: var(--card-bg); border: 1rpx solid var(--border-color);
  font-size: 24rpx; color: var(--text-primary);
  transition: all 0.2s;
}
.template-chip:active { background: rgba(126,200,227,0.1); border-color: #7EC8E3; }

/* 表单 */
.form-body { margin-bottom: 24rpx; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--card-bg); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.form-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--card-bg); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
}
.form-picker.placeholder { color: #CCC; }
.form-textarea {
  width: 100%; height: 160rpx; padding: 16rpx 20rpx;
  background: var(--card-bg); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
  box-sizing: border-box;
}

/* 免责声明 */
.disclaimer {
  padding: 16rpx 20rpx; border-radius: 16rpx;
  background: rgba(250,173,20,0.06); border: 1rpx solid rgba(250,173,20,0.15);
  margin-bottom: 24rpx;
}
.disclaimer text { font-size: 22rpx; color: #996600; line-height: 1.5; }

/* 保存按钮 */
.save-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--card-bg); border-top: 1rpx solid var(--border-color);
}
.save-btn {
  width: 100%; padding: 24rpx 0; text-align: center;
  background: linear-gradient(135deg, #FF9F5A, #FFB87C);
  border-radius: 16rpx; color: #FFF; font-size: 30rpx; font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(255,159,90,0.3);
}
.save-btn:active { transform: scale(0.98); }
