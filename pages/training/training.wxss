.page { padding: 24rpx 32rpx; }
.fade-in { animation: fadeInUp 0.4s ease-out both; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }

.page-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; }
.pet-picker { display: inline-flex; align-items: center; gap: 12rpx; padding: 14rpx 28rpx; border-radius: 24rpx; background: var(--card-bg); box-shadow: var(--shadow); font-size: 28rpx; color: var(--text-primary); margin-bottom: 28rpx; }

.streak-banner { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; background: linear-gradient(135deg, rgba(255,159,90,0.1), rgba(255,77,79,0.06)); border-radius: 20rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(255,159,90,0.15); }
.streak-banner__fire { font-size: 48rpx; }
.streak-banner__info { flex: 1; }
.streak-banner__num { font-size: 30rpx; font-weight: 700; color: #FF9F5A; display: block; }
.streak-banner__tip { font-size: 22rpx; color: var(--text-secondary); line-height: 1.5; }

.section { margin-bottom: 28rpx; }
.card { background: var(--card-bg); border-radius: 28rpx; padding: 28rpx; box-shadow: var(--shadow); }
.section__header { margin-bottom: 20rpx; }
.section__title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }

/* 技能网格 */
.skill-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.skill-card {
  width: calc(50% - 8rpx); background: var(--card-bg);
  border-radius: 24rpx; padding: 24rpx; box-shadow: var(--shadow);
  transition: transform 0.2s; border: 2rpx solid transparent;
}
.skill-card:active { transform: scale(0.97); }
.skill-card__top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.skill-card__name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.skill-card__badge-wrap { display: flex; flex-direction: column; align-items: center; }
.skill-card__badge { font-size: 28rpx; }
.skill-card__badge-name { font-size: 18rpx; color: var(--text-secondary); }

.skill-card__progress { margin-bottom: 12rpx; }
.skill-card__bar { height: 14rpx; background: rgba(255,159,90,0.08); border-radius: 7rpx; overflow: hidden; }
.skill-card__bar-fill { height: 100%; background: linear-gradient(90deg, #FF9F5A, #FFB87C); border-radius: 7rpx; transition: width 0.8s ease; }

.skill-card__bottom { display: flex; justify-content: space-between; align-items: center; }
.skill-card__count { font-size: 22rpx; color: var(--text-secondary); }
.skill-card__rate { font-size: 26rpx; font-weight: 700; }

/* 本周报告 */
.report-card {
  display: flex; justify-content: space-around; align-items: center;
}
.report-item { text-align: center; }
.report-num { font-size: 48rpx; font-weight: 700; color: #FF9F5A; display: block; }
.report-ring {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  border: 8rpx solid rgba(255,159,90,0.15);
  display: flex; align-items: center; justify-content: center;
}
.report-ring__val { font-size: 28rpx; font-weight: 700; color: #FF9F5A; }
.report-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 8rpx; }

.report-commands { display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid var(--border-color); }
.report-commands__label { font-size: 22rpx; color: var(--text-secondary); }

/* FAB */
.fab-btn {
  position: fixed; right: 40rpx; bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #52C41A, #73d13d);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(82,196,26,0.4); z-index: 100;
  font-size: 48rpx; color: #FFF;
}
.fab-btn:active { transform: scale(0.9); }

/* Modal */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; display: flex; align-items: flex-end; }
.modal-content {
  width: 100%; max-height: 85vh; background: var(--card-bg); border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid var(--border-color); }
.modal-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.modal-close { font-size: 32rpx; color: var(--text-secondary); padding: 8rpx; }
.modal-body { flex: 1; padding: 24rpx 32rpx; overflow-y: auto; max-height: 60vh; }
.modal-footer { display: flex; gap: 16rpx; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.modal-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 30rpx; font-weight: 500; }
.modal-btn.cancel { background: var(--border-color); color: var(--text-secondary); }
.modal-btn.confirm { background: linear-gradient(135deg, #52C41A, #73d13d); color: #FFF; }

/* Form */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
.form-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary);
}
.form-textarea {
  width: 100%; height: 120rpx; padding: 16rpx 20rpx;
  background: var(--bg-color, #FFF8F0); border: 2rpx solid var(--border-color, #EEE);
  border-radius: 16rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box;
}
