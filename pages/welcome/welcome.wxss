.welcome {
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: linear-gradient(160deg, #FFF8F0, #FFE8D6, #FFF0E6);
  position: relative; overflow: hidden;
}

/* 背景装饰 */
.welcome__bg { position: absolute; inset: 0; pointer-events: none; }
.welcome__circle {
  position: absolute; border-radius: 50%; opacity: 0.15;
}
.welcome__circle.c1 { width: 400rpx; height: 400rpx; background: #FF9F5A; top: -100rpx; right: -100rpx; }
.welcome__circle.c2 { width: 300rpx; height: 300rpx; background: #7EC8E3; bottom: 200rpx; left: -80rpx; }
.welcome__circle.c3 { width: 200rpx; height: 200rpx; background: #FFB5C2; top: 300rpx; right: 60rpx; }

.welcome__content {
  position: relative; z-index: 1; text-align: center;
  padding: 0 60rpx; animation: fadeInUp 0.5s ease-out;
}
@keyframes fadeInUp { from { opacity:0; transform:translateY(40rpx); } to { opacity:1; transform:translateY(0); } }

.welcome__logo { display: flex; flex-direction: column; align-items: center; }
.welcome__emoji { font-size: 120rpx; margin-bottom: 32rpx; animation: bounce 2s ease infinite; }
@keyframes bounce { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-20rpx); } }
.welcome__title { font-size: 52rpx; font-weight: 800; color: #333; margin-bottom: 16rpx; }
.welcome__subtitle { font-size: 30rpx; color: #888; }

.welcome__step { display: flex; flex-direction: column; align-items: center; }
.welcome__step-emoji { font-size: 100rpx; margin-bottom: 40rpx; }
.welcome__step-title { font-size: 44rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; }
.welcome__step-desc { font-size: 28rpx; color: #666; line-height: 1.8; white-space: pre-line; }

.welcome__dots {
  display: flex; gap: 12rpx; margin: 60rpx 0 40rpx;
  position: relative; z-index: 1;
}
.welcome__dot {
  width: 12rpx; height: 12rpx; border-radius: 6rpx;
  background: rgba(255,159,90,0.2); transition: all 0.3s;
}
.welcome__dot.active { width: 36rpx; background: #FF9F5A; }

.welcome__actions {
  display: flex; flex-direction: column; align-items: center; gap: 20rpx;
  position: relative; z-index: 1; width: 100%; padding: 0 80rpx;
}
.welcome__btn {
  width: 100%; height: 96rpx; line-height: 96rpx;
  background: linear-gradient(135deg, #FF9F5A, #FFB87C);
  color: #FFF; font-size: 32rpx; font-weight: 600;
  border-radius: 48rpx; border: none;
  box-shadow: 0 8rpx 30rpx rgba(255,159,90,0.4);
}
.welcome__btn::after { border: none; }
.welcome__skip { font-size: 26rpx; color: #888; }
